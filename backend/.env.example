# Database — use Render PostgreSQL internal URL in production
# Example: postgresql+asyncpg://user:password@dpg-xxxxx-a/render_db_name
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/nexus

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=YOUR_SECRET_KEY_CHANGE_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins) — include your deployed frontend URL
# Production example:
CORS_ORIGINS=https://www.rconnectx.com,https://rconnectx.com,http://localhost:3000,http://127.0.0.1:3000

# OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
# Must match GitHub OAuth app callback URL (optional if FRONTEND_URL is set)
# Example: https://www.rconnectx.com/github/callback
GITHUB_REDIRECT_URI=https://www.rconnectx.com/github/callback

# Email
RESEND_API_KEY=YOUR_RESEND_API_KEY
FROM_EMAIL=noreply@yourdomain.com

# External APIs
GNEWS_API_KEY=YOUR_GNEWS_API_KEY
DEVTO_API_KEY=

# App
APP_NAME=Nexus API
# Production frontend URL — used for password-reset links and OAuth redirects
# Example: https://www.rconnectx.com
FRONTEND_URL=https://www.rconnectx.com
DEBUG=false
API_PREFIX=/api

# Cloudinary — required in production for persistent media storage
# Create a free account at https://cloudinary.com and copy credentials from the dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=rconnectx

# Web Push (VAPID) — required for browser push when tab is closed
# Generate keys: python backend/scripts/generate_vapid_keys.py
# Render: paste VAPID_PRIVATE_KEY as a single line with literal \n between PEM lines
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@rconnectx.com
