# Database — use Render PostgreSQL internal URL in production
# Example: postgresql+asyncpg://user:password@dpg-xxxxx-a/render_db_name
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/nexus

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=YOUR_SECRET_KEY_CHANGE_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins) — include your deployed frontend URL
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
# Must match GitHub OAuth app callback URL
# Example: https://your-app.vercel.app/github/callback
GITHUB_REDIRECT_URI=http://localhost:3000/github/callback

# Email
RESEND_API_KEY=YOUR_RESEND_API_KEY
FROM_EMAIL=noreply@yourdomain.com

# External APIs
GNEWS_API_KEY=YOUR_GNEWS_API_KEY
DEVTO_API_KEY=

# App
APP_NAME=Nexus API
# Production frontend URL — used for password-reset links and redirects
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
DEBUG=false
API_PREFIX=/api
