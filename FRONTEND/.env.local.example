# Backend API — required in production builds
NEXT_PUBLIC_API_URL=https://nexus-4ygl.onrender.com/api

# Deployed frontend URL — used by Next.js API routes (Google Calendar OAuth redirect)
NEXT_PUBLIC_APP_URL=https://your-frontend-domain.com

# Google OAuth (same client ID as backend GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# Optional — only if calling GNews directly from the browser (feed page)
# Prefer routing through backend /api/news in production
NEXT_PUBLIC_GNEWS_API_KEY=
